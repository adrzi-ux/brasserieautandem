---
import Site from '~/layouts/Site.astro';
import Stamp from '~/components/Stamp.astro';
import CTABanner from '~/components/CTABanner.astro';
import Newsletter from '~/components/Newsletter.astro';
import { PAIRINGS_ROUGES as ROUGES, PAIRINGS_ROSES as ROSES, PAIRINGS_BLANCS as BLANCS } from '~/data/pairings';
---

<Site title="Accords mets-vins" description="11 accords mets-vins choisis par notre sommelier : rouges du Rhône sud, rosés de Provence, blancs de Cassis et Bandol." activePage="accords">
  <section class="section" style="padding-top: 60px; padding-bottom: 0;">
    <div class="container">
      <div style="display: grid; grid-template-columns: 1.4fr 1fr; gap: 60px; align-items: end; position: relative;">
        <h1 class="h-page" style="max-width: 16ch;">
          Le bon <em>verre</em><br/>
          pour le bon <em>plat</em>.
        </h1>
        <p class="lede" style="max-width: 40ch;">
          Onze accords mets-vins choisis par notre sommelier, classés par
          couleur. Toutes les bouteilles citées sont disponibles à la carte
          du Tandem.
        </p>
        <Stamp text="SÉLECTION SOMMELIER · MAI 2026 ·" center="Vino" size={140} color="terracotta" rot={-10}
          style="position: absolute; right: -10px; top: -40px;" />
      </div>
    </div>
  </section>

  <section class="wine-block" style="margin-top: 80px;">
    <div class="container">
      <div style="display: flex; justify-content: space-between; align-items: end; margin-bottom: 40px; gap: 40px;">
        <div>
          <div class="eyebrow" style="color: #C77B30;">
            <span class="dot" style="background: #C77B30;"></span>I. Les rouges
          </div>
          <h2 class="h-section" style="color: var(--cream); margin-top: 18px;">
            Pour les plats <em style="color: var(--cream); font-style: italic;">mijotés</em>.
          </h2>
        </div>
        <p class="lede" style="max-width: 36ch; color: rgba(245,239,224,0.7);">
          Daubes, gibier, agneau. Les rouges du Rhône sud et de Provence portent
          naturellement les longues cuissons.
        </p>
      </div>
      <table class="wine-table">
        <thead>
          <tr>
            <th style="width: 28%;">Plat</th>
            <th style="width: 22%;">Vin suggéré</th>
            <th style="width: 18%;">Appellation</th>
            <th>Pourquoi ça marche</th>
          </tr>
        </thead>
        <tbody>
          {ROUGES.map((p) => (
            <tr>
              <td class="dish">{p.dish}</td>
              <td class="wine">{p.wine}</td>
              <td class="region" style="color: #C77B30;">{p.region}</td>
              <td class="note">{p.note}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="section" style="background: #E8C9B4; padding-top: 80px; padding-bottom: 80px;">
    <div class="container">
      <div style="display: flex; justify-content: space-between; align-items: end; margin-bottom: 40px; gap: 40px;">
        <div>
          <div class="eyebrow"><span class="dot"></span>II. Les rosés</div>
          <h2 class="h-section" style="margin-top: 18px;">
            Pour les plats <em class="flourish">d'été</em>.
          </h2>
        </div>
        <p class="lede" style="max-width: 36ch;">
          Tians, salades, apéro de bord de mer. Le rosé n'est pas une concession :
          c'est un vin à part entière.
        </p>
      </div>

      <table class="wine-table" style="color: var(--ink);">
        <thead>
          <tr>
            <th style="width: 28%; color: var(--ink-soft); border-bottom-color: rgba(61,40,23,0.3);">Plat</th>
            <th style="width: 22%; color: var(--ink-soft); border-bottom-color: rgba(61,40,23,0.3);">Vin suggéré</th>
            <th style="width: 18%; color: var(--ink-soft); border-bottom-color: rgba(61,40,23,0.3);">Appellation</th>
            <th style="color: var(--ink-soft); border-bottom-color: rgba(61,40,23,0.3);">Pourquoi ça marche</th>
          </tr>
        </thead>
        <tbody>
          {ROSES.map((p) => (
            <tr style="border-color: rgba(61,40,23,0.18);">
              <td class="dish">{p.dish}</td>
              <td class="wine">{p.wine}</td>
              <td class="region" style="color: var(--terracotta-deep);">{p.region}</td>
              <td class="note" style="color: var(--ink-soft);">{p.note}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="wine-block">
    <div class="container">
      <div style="display: flex; justify-content: space-between; align-items: end; margin-bottom: 40px; gap: 40px;">
        <div>
          <div class="eyebrow" style="color: #9B7DB9;">
            <span class="dot" style="background: #9B7DB9;"></span>III. Les blancs
          </div>
          <h2 class="h-section" style="color: var(--cream); margin-top: 18px;">
            Pour la <em style="color: var(--cream); font-style: italic;">mer</em> et le <em style="color: var(--cream); font-style: italic;">poisson</em>.
          </h2>
        </div>
        <p class="lede" style="max-width: 36ch; color: rgba(245,239,224,0.7);">
          Bandol, Cassis, Coteaux du Pic — des blancs salins du Sud, qui ne sucrent
          jamais et tiennent la morue, l'aïoli, la bouillabaisse.
        </p>
      </div>
      <table class="wine-table">
        <thead>
          <tr>
            <th style="width: 28%;">Plat</th>
            <th style="width: 22%;">Vin suggéré</th>
            <th style="width: 18%;">Appellation</th>
            <th>Pourquoi ça marche</th>
          </tr>
        </thead>
        <tbody>
          {BLANCS.map((p) => (
            <tr>
              <td class="dish">{p.dish}</td>
              <td class="wine">{p.wine}</td>
              <td class="region" style="color: #9B7DB9;">{p.region}</td>
              <td class="note">{p.note}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <CTABanner />
  <Newsletter />
</Site>
