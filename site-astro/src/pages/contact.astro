---
import Site from '~/layouts/Site.astro';
import Stamp from '~/components/Stamp.astro';
import Placeholder from '~/components/Placeholder.astro';
import Icon from '~/components/Icon.astro';
import Newsletter from '~/components/Newsletter.astro';
import { SITE } from '~/data/site';

const hours: [string, string][] = [
  ['Lundi',    '6h30 — 22h'],
  ['Mardi',    '6h30 — 22h'],
  ['Mercredi', '6h30 — 22h'],
  ['Jeudi',    '6h30 — 22h'],
  ['Vendredi', '6h30 — 23h'],
  ['Samedi',   '7h00 — 23h'],
  ['Dimanche', '8h00 — 16h'],
];
---

<Site title="Contact & réservation" description="Brasserie Au Tandem · 16 rue de l'église, La Roque-d'Anthéron · 04 42 59 68 49. Ouvert dès 6h30.">
  <section class="section" style="padding-top: 60px; padding-bottom: 30px;">
    <div class="container">
      <div class="crumb">
        <a href="/">Accueil</a><span class="sep">/</span><span>Contact</span>
      </div>
      <div style="display: grid; grid-template-columns: 1.5fr 1fr; align-items: end; gap: 60px;">
        <h1 class="h-page" style="max-width: 18ch;">
          Venir au <em>Tandem</em>,<br />
          ou nous <em>écrire</em>.
        </h1>
        <p class="lede" style="max-width: 40ch;">
          Pour réserver, demander un menu de groupe ou simplement nous dire que la
          fougasse vous a plu — on lit tout.
        </p>
      </div>
    </div>
  </section>

  <section class="section" style="padding-top: 30px;">
    <div class="container">
      <div style="display: grid; grid-template-columns: 1fr 1.2fr; gap: 80px;">
        <div>
          <div class="eyebrow"><span class="dot"></span>L'adresse</div>
          <div class="serif" style="font-size: 36px; line-height: 1.15; margin: 16px 0 30px; max-width: 18ch;">
            {SITE.address.street},<br />
            {SITE.address.city},<br />
            <em style="color: var(--terracotta-deep);">{SITE.address.zip} — {SITE.address.region}</em>
          </div>
          <div style="display: flex; gap: 20px; margin-bottom: 36px; color: var(--ink-soft); font-size: 14px;">
            <span><Icon name="phone" size={14} stroke={1.4} /> {SITE.phone}</span>
            <span><Icon name="ig" size={14} stroke={1.4} /> {SITE.instagram}</span>
          </div>

          <div class="map-block" style="aspect-ratio: 16/11; margin-bottom: 30px;">
            <Placeholder tone="olive" label="Carte · La Roque-d'Anthéron, Bouches-du-Rhône" />
            <span class="map-pin" style="top: 52%; left: 48%;">T</span>
          </div>

          <div class="eyebrow"><span class="dot"></span>Horaires</div>
          <table class="hours-table" style="margin-top: 14px;">
            <tbody>
              {hours.map(([d, h]) => (
                <tr>
                  <td class="day">{d}</td>
                  <td class="h">{h}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <div>
          <div style="background: var(--cream); padding: 44px; position: relative;">
            <Stamp text="RÉSERVATION · MERCI ·" center="✓" size={100} color="terracotta" rot={6}
              style="position: absolute; right: -20px; top: -28px;" />
            <div class="eyebrow"><span class="dot"></span>Réserver une table</div>
            <h2 class="serif" style="font-size: 42px; line-height: 1.05; margin: 18px 0 30px; max-width: 14ch;">
              Dites-nous <em style="color: var(--terracotta-deep);">quand</em>.
            </h2>

            <form class="form-grid" action="#" method="post">
              <div class="form-row duo">
                <div><label>Nom</label><input type="text" name="nom" /></div>
                <div><label>Téléphone</label><input type="tel" name="tel" /></div>
              </div>
              <div class="form-row"><label>Email</label><input type="email" name="email" /></div>
              <div class="form-row duo">
                <div><label>Date</label><input type="date" name="date" /></div>
                <div>
                  <label>Personnes</label>
                  <select name="personnes">
                    <option>1</option><option selected>2</option><option>3</option><option>4</option>
                    <option>5</option><option>6+</option>
                  </select>
                </div>
              </div>
              <div class="form-row"><label>Message</label><textarea name="message" placeholder="Un mot, un anniversaire, une allergie…"></textarea></div>
              <button type="submit" class="btn btn-primary" style="justify-self: start; margin-top: 8px;">
                Envoyer la demande <span class="arrow">→</span>
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Newsletter />
</Site>
