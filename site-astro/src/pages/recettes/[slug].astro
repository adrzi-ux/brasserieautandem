---
import Site from '~/layouts/Site.astro';
import Placeholder from '~/components/Placeholder.astro';
import Stamp from '~/components/Stamp.astro';
import RecipeCard from '~/components/RecipeCard.astro';
import CTABanner from '~/components/CTABanner.astro';
import Newsletter from '~/components/Newsletter.astro';
import { RECIPES, type Recipe } from '~/data/recipes';
import { SITE } from '~/data/site';

export function getStaticPaths() {
  return RECIPES.map((r) => ({
    params: { slug: r.slug },
    props: { recipe: r },
  }));
}

interface Props {
  recipe: Recipe;
}

const { recipe } = Astro.props;

// 3 recettes liées (même catégorie, hors fiche courante)
const related = RECIPES
  .filter((r) => r.category === recipe.category && r.slug !== recipe.slug)
  .slice(0, 3);

const categoryLabels: Record<Recipe['category'], string> = {
  provencales: 'Recettes provençales',
  mediterraneennes: 'Recettes méditerranéennes',
  saisonnieres: 'Recettes saisonnières',
};
const categoryHref: Record<Recipe['category'], string> = {
  provencales: '/recettes-provencales/',
  mediterraneennes: '/recettes-mediterraneennes/',
  saisonnieres: '/recettes-saisonnieres/',
};

// JSON-LD Schema.org Recipe pour rich snippets Google
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Recipe',
  name: recipe.title,
  description: recipe.intro,
  recipeCategory: categoryLabels[recipe.category],
  recipeCuisine: recipe.category === 'mediterraneennes' ? 'Méditerranéenne' : 'Provençale',
  keywords: recipe.keywords,
  author: {
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
  },
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
  },
  prepTime: recipe.prepTimeISO,
  cookTime: recipe.cookTimeISO,
  totalTime: recipe.totalTimeISO,
  recipeYield: `${recipe.serves} personnes`,
  recipeIngredient: recipe.ingredients.map(i => `${i.qty} ${i.item}`.trim()),
  recipeInstructions: recipe.steps.map((step, i) => ({
    '@type': 'HowToStep',
    name: `Étape ${i + 1}`,
    text: step,
    position: i + 1,
  })),
};

const tipsCols = Math.min(recipe.tips.length, 3);
const tipsStyle = `display: grid; grid-template-columns: repeat(${tipsCols}, 1fr); gap: 1px; background: var(--rule); border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule);`;
---

<Site
  title={recipe.title}
  description={recipe.intro}
  activePage="recettes"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <section class="fb-hero" style="height: clamp(420px, 50vh, 600px);">
    <div class="bg">
      <Placeholder tone={recipe.tone} label={`Hero · ${recipe.title}`} />
    </div>
    <div class="container">
      <div style="position: relative;">
        <div class="eyebrow" style="color: rgba(245,239,224,0.75); margin-bottom: 18px;">
          <span class="dot" style="background: rgba(245,239,224,0.75);"></span>
          {categoryLabels[recipe.category]} · N°{recipe.num}
        </div>
        <h1 class="h-page" style="max-width: 18ch;">{recipe.title}</h1>
        <p class="lede" style="max-width: 50ch; margin-top: 22px;">{recipe.intro}</p>
      </div>
    </div>
  </section>

  <section class="recipe-bar" style="top: 0; position: relative;">
    <div class="container">
      <div class="stat">
        <div class="k">Préparation</div>
        <div class="v">{recipe.time.split('+')[0] || recipe.time}</div>
      </div>
      <div class="stat">
        <div class="k">Difficulté</div>
        <div class="v">{recipe.diff}</div>
      </div>
      <div class="stat">
        <div class="k">Personnes</div>
        <div class="v">{recipe.serves}</div>
      </div>
      <div class="stat">
        <div class="k">Catégorie</div>
        <div class="v" style="font-size: 16px;">
          <a href={categoryHref[recipe.category]} style="color: inherit;">
            {recipe.category === 'provencales' ? 'Provençale' : recipe.category === 'mediterraneennes' ? 'Méditerranéenne' : 'Saisonnière'}
          </a>
        </div>
      </div>
      <a href="#ingredients" class="btn btn-primary">Aux ingrédients <span class="arrow">→</span></a>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="two-col">
        <div>
          <div class="eyebrow"><span class="dot"></span>Le mot de la maison</div>
          <h2 class="h-section" style="margin-top: 18px; max-width: 14ch;">
            <em class="flourish">L'histoire</em> derrière la recette.
          </h2>
        </div>
        <div class="intro-prose">
          <p class="dropcap">{recipe.story}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="ingredients" style="background: var(--cream); padding-top: clamp(48px, 6vw, 90px);">
    <div class="container">
      <div class="recipe-body">
        <div>
          <div class="eyebrow"><span class="dot"></span>Pour {recipe.serves} personnes</div>
          <h2 class="h-section" style="margin-top: 18px; margin-bottom: 32px;">
            Ingré<em class="flourish">dients</em>.
          </h2>
          <ul class="ing-list">
            {recipe.ingredients.map((i) => (
              <li>
                <span class="qty">{i.qty}</span>
                <span>{i.item}</span>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <div class="eyebrow"><span class="dot"></span>{recipe.steps.length} étapes</div>
          <h2 class="h-section" style="margin-top: 18px; margin-bottom: 32px;">
            Prépa<em class="flourish">ration</em>.
          </h2>
          <ol class="steps">
            {recipe.steps.map((step) => (
              <li>{step}</li>
            ))}
          </ol>
        </div>
      </div>
    </div>
  </section>

  {recipe.tips.length > 0 && (
    <section class="section" style="padding-top: clamp(40px, 5vw, 70px);">
      <div class="container">
        <div class="section-head">
          <div class="left">
            <div class="eyebrow"><span class="dot"></span>Variantes & conseils</div>
            <h2 class="h-section" style="margin-top: 18px;">
              <em class="flourish">À retenir</em> en cuisine.
            </h2>
          </div>
        </div>
        <div style={tipsStyle}>
          {recipe.tips.map((tip, i) => (
            <div style="background: var(--paper); padding: 32px 28px; min-height: 180px;">
              <div class="serif" style="font-style: italic; font-size: 42px; color: var(--terracotta-deep); line-height: 1;">
                {String(i + 1).padStart(2, '0')}.
              </div>
              <p style="color: var(--ink); font-size: 16px; line-height: 1.55; margin-top: 16px; text-wrap: pretty;">
                {tip}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {recipe.wineMatch && (
    <section class="wine-block">
      <div class="container">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: end; position: relative;">
          <div>
            <div class="eyebrow"><span class="dot"></span>Accord mets-vin</div>
            <h2 class="h-section" style="color: var(--cream); margin-top: 18px;">
              Avec quel <em style="color: var(--cream); font-style: italic;">verre</em> ?
            </h2>
          </div>
          <Stamp text="ACCORD SOMMELIER · MAISON ·" center="Vino" size={120} color="terracotta" rot={-8}
            style="position: absolute; right: 0; top: -20px;" />
        </div>
        <table class="wine-table" style="margin-top: 32px;">
          <thead>
            <tr>
              <th style="width: 28%;">Plat</th>
              <th style="width: 22%;">Vin suggéré</th>
              <th style="width: 18%;">Appellation</th>
              <th>Pourquoi ça marche</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="dish">{recipe.title}</td>
              <td class="wine">{recipe.wineMatch.wine}</td>
              <td class="region">{recipe.wineMatch.region}</td>
              <td class="note">{recipe.wineMatch.note}</td>
            </tr>
          </tbody>
        </table>
        <div style="margin-top: 32px;">
          <a href="/accords-mets-vins/" class="btn btn-on-dark">Tous les accords mets-vins <span class="arrow">→</span></a>
        </div>
      </div>
    </section>
  )}

  {related.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-head">
          <div class="left">
            <div class="eyebrow"><span class="dot"></span>Du même registre</div>
            <h2 class="h-section" style="margin-top: 18px;">
              À <em class="flourish">essayer ensuite</em>.
            </h2>
          </div>
          <div class="right">
            <a href={categoryHref[recipe.category]} class="btn btn-ghost">Toutes les {categoryLabels[recipe.category].toLowerCase()} <span class="arrow">→</span></a>
          </div>
        </div>
        <div class="recipe-grid">
          {related.map((r) => (
            <RecipeCard
              tag={r.tag}
              title={r.title}
              time={r.time}
              diff={r.diff}
              tone={r.tone}
              num={r.num}
              href={`/recettes/${r.slug}/`}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <CTABanner />
  <Newsletter />
</Site>
