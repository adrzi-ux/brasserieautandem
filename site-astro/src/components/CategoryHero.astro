---
import Placeholder from './Placeholder.astro';
import Stamp from './Stamp.astro';

type Tone = 'warm' | 'olive' | 'cocoa' | 'sand' | 'lav' | 'rose';

interface CrumbItem {
  label: string;
  href?: string;
}

interface Props {
  crumb: CrumbItem[];
  title: string;
  lede: string;
  tone?: Tone;
  stampText?: string;
  stampCenter?: string;
  stampColor?: 'terracotta' | 'brown' | 'olive';
}

const {
  crumb,
  title,
  lede,
  tone = 'rose',
  stampText,
  stampCenter,
  stampColor = 'terracotta',
} = Astro.props;
---

<section class="fb-hero">
  <div class="bg">
    <Placeholder tone={tone} label={`Hero · ${title.replace(/<[^>]+>/g, '')}`} />
  </div>
  <div class="container">
    <div style="position: relative; margin-top: auto;">
      <h1 class="h-page" set:html={title} />
      <p class="lede">{lede}</p>
      {stampText && (
        <Stamp text={stampText} center={stampCenter} size={140} color={stampColor} rot={-12}
          style="position: absolute; right: 0; top: -10px;" />
      )}
    </div>
  </div>
</section>
