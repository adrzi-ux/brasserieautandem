---
import { SITE } from '~/data/site';

interface Props {
  activePage?: 'recettes' | 'accords' | 'producteurs' | 'brasserie' | 'apropos';
}

const { activePage } = Astro.props;
---

<header class="site-header">
  <div class="container row">
    <a href="/" class="brand">
      <span class="brand-mark">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
          <circle cx="6" cy="16" r="4" />
          <circle cx="18" cy="16" r="4" />
          <path d="M6 16l3-7h6l3 7" />
          <path d="M9 9h6" />
          <path d="M11 16l-1-4M14 16l-1-4" />
        </svg>
      </span>
      <span class="brand-words">
        Au Tandem
        <small>{SITE.tagline}</small>
      </span>
    </a>
    <nav class="nav-main">
      <a href="/recettes/" class={activePage === 'recettes' ? 'active' : ''}>Recettes</a>
      <a href="/accords-mets-vins/" class={activePage === 'accords' ? 'active' : ''}>Accords mets-vins</a>
      <a href="/producteurs-locaux/" class={activePage === 'producteurs' ? 'active' : ''}>Producteurs</a>
      <a href="/notre-brasserie/" class={activePage === 'brasserie' ? 'active' : ''}>Notre brasserie</a>
      <a href="/a-propos/" class={activePage === 'apropos' ? 'active' : ''}>À propos</a>
    </nav>
    <div class="header-cta">
      <span class="phone">{SITE.phone}</span>
      <a href="/contact/" class="btn btn-ghost" style="padding: 10px 18px;">Réserver</a>
    </div>
  </div>
</header>
