---
import { SITE } from '~/data/site';
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <div class="brand" style="margin-bottom: 18px;">
          <span class="brand-mark">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
              <circle cx="6" cy="16" r="4" /><circle cx="18" cy="16" r="4" />
              <path d="M6 16l3-7h6l3 7" /><path d="M9 9h6" />
            </svg>
          </span>
          <span class="brand-words">Au Tandem<small>{SITE.tagline}</small></span>
        </div>
        <p style="max-width: 32ch; color: var(--ink-soft); font-size: 13.5px; line-height: 1.6;">
          Cuisine provençale, accords mets-vins et carnet d'adresses du Luberon.
          Pensé à {SITE.address.city}, {SITE.address.zip}.
        </p>
      </div>
      <div>
        <h4>Recettes</h4>
        <ul>
          <li><a href="/recettes-provencales/">Provençales</a></li>
          <li><a href="/recettes-mediterraneennes/">Méditerranéennes</a></li>
          <li><a href="/recettes-saisonnieres/">Saisonnières</a></li>
          <li><a href="/accords-mets-vins/">Accords mets-vins</a></li>
        </ul>
      </div>
      <div>
        <h4>La maison</h4>
        <ul>
          <li><a href="/notre-brasserie/">Notre brasserie</a></li>
          <li><a href="/producteurs-locaux/">Producteurs locaux</a></li>
          <li><a href="/a-propos/">À propos</a></li>
          <li><a href="/contact/">Contact</a></li>
        </ul>
      </div>
      <div>
        <h4>Suivre</h4>
        <ul>
          <li><a href="#">Instagram</a></li>
          <li><a href="#">Facebook</a></li>
          <li><a href="#">La lettre</a></li>
          <li><a href="#">RSS recettes</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© 2026 {SITE.name} — {SITE.address.city}</span>
      <span>Mentions légales · Confidentialité</span>
    </div>
  </div>
</footer>
